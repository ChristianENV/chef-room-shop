# Database
DATABASE_URL="postgresql://user:password@host:5432/chefroom?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Conekta (sandbox) — server-only private key; never expose to client
CONEKTA_PRIVATE_KEY=""
NEXT_PUBLIC_CONEKTA_PUBLIC_KEY=""
CONEKTA_WEBHOOK_SECRET=""
CONEKTA_WEBHOOK_PUBLIC_KEY=""
CONEKTA_API_VERSION="2.2.0"
CONEKTA_ENV="sandbox"

# Email (transactional v1)
EMAIL_PROVIDER="console"
EMAIL_FROM="Chef Room <no-reply@chefroom.mx>"

# Resend (when EMAIL_PROVIDER=resend)
RESEND_API_KEY=""

# Mailtrap optional (when EMAIL_PROVIDER=mailtrap)
MAILTRAP_TOKEN=""
MAILTRAP_INBOX_ID=""
MAILTRAP_ACCOUNT_ID=""
