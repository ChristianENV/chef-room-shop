# Database
DATABASE_URL="postgresql://user:password@host:5432/chefroom?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Conekta (sandbox) — server-only private key; never expose to client
CONEKTA_PRIVATE_KEY=""
NEXT_PUBLIC_CONEKTA_PUBLIC_KEY=""
CONEKTA_WEBHOOK_SECRET=""
CONEKTA_WEBHOOK_PUBLIC_KEY=""
CONEKTA_API_VERSION="2.2.0"
CONEKTA_ENV="sandbox"

# Email (transactional v1)
EMAIL_PROVIDER="console"
EMAIL_FROM="Chef Room <no-reply@chefroom.mx>"

# Resend (when EMAIL_PROVIDER=resend)
RESEND_API_KEY=""

# Mailtrap optional (when EMAIL_PROVIDER=mailtrap)
MAILTRAP_TOKEN=""
MAILTRAP_INBOX_ID=""
MAILTRAP_ACCOUNT_ID=""

# Skydropx PRO (server-only — never expose CLIENT_SECRET to the client)
SKYDROPX_ENV="sandbox"
SKYDROPX_API_BASE_URL="https://api-pro.skydropx.com"
SKYDROPX_CLIENT_ID=""
SKYDROPX_CLIENT_SECRET=""
SKYDROPX_WEBHOOK_SECRET=""

# Shipping origin (Chef Room — Puebla)
SHIPPING_ORIGIN_NAME="Chef Room"
SHIPPING_ORIGIN_COMPANY="Chef Room by Bedolla"
SHIPPING_ORIGIN_PHONE=""
SHIPPING_ORIGIN_EMAIL=""
SHIPPING_ORIGIN_STREET=""
SHIPPING_ORIGIN_EXT_NUMBER=""
SHIPPING_ORIGIN_INT_NUMBER=""
SHIPPING_ORIGIN_NEIGHBORHOOD=""
SHIPPING_ORIGIN_CITY="Puebla"
SHIPPING_ORIGIN_STATE="Puebla"
SHIPPING_ORIGIN_COUNTRY="MX"
SHIPPING_ORIGIN_POSTAL_CODE="72000"

# Shipping package defaults (single garment baseline)
SHIPPING_DEFAULT_PACKAGE_LENGTH_CM="30"
SHIPPING_DEFAULT_PACKAGE_WIDTH_CM="20"
SHIPPING_DEFAULT_PACKAGE_HEIGHT_CM="5"
SHIPPING_DEFAULT_PACKAGE_WEIGHT_KG="0.5"

# Checkout dev only — allow advancing without a shipping rate when Skydropx is unavailable (UI)
# NEXT_PUBLIC_ALLOW_CHECKOUT_WITHOUT_SHIPPING="true"

# Server-only — allow createCheckoutOrder without shippingRateId (shippingCents = 0). Not for production.
# ALLOW_CHECKOUT_WITHOUT_SHIPPING="false"
