# Neon PostgreSQL (required for Prisma migrate / seed)
# Example: postgresql://USER:PASSWORD@ep-example.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@ep-example.us-east-1.aws.neon.tech/neondb?sslmode=require"

# App
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Better Auth
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (Better Auth social provider — UI not wired yet)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Deprecated: custom BFF callback; Better Auth uses /api/auth/callback/google
# GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Optional future social providers (configure in build-auth.ts when needed)
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# Optional DEV admin seed (npm run db:seed) — do not use in production
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_FIRST_NAME="Admin"
SEED_ADMIN_LAST_NAME="Chef Room"

# Enforce admin session cookie in middleware (full RBAC in server layouts)
# ADMIN_AUTH_ENFORCE="true"

# Future integrations (not required for schema v1)
# CONEKTA_PRIVATE_KEY=""
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
# REDIS_URL=""
